  &lt;div class=&#34;caption-group&#34;&gt;
整组图片总题注（放在所有子图下方）
&lt;/div&gt;
  
&lt;/div&gt;

&lt;div id=&#34;lightbox-64983527&#34;&gt;
  &lt;img id=&#34;lightbox-img-64983527&#34; alt=&#34;fullscreen&#34;&gt;
&lt;/div&gt;

&lt;script&gt;
(function(){
  const root = document.querySelector(&#39;.picture-card-wrap-64983527&#39;);
  if (!root) return;

  const items = root.querySelectorAll(&#39;.img-container&#39;);
  const lightbox = document.getElementById(&#39;lightbox-64983527&#39;);
  const lightImg = document.getElementById(&#39;lightbox-img-64983527&#39;);

  items.forEach(el =&gt; {
    el.onclick = function() {
      lightImg.src = this.dataset.src;
      lightbox.style.display = &#39;flex&#39;;
    }
  });

  
  document.addEventListener(&#39;keydown&#39;, function escClose(e) {
    if (e.key === &#39;Escape&#39;) {
      lightbox.style.display = &#39;none&#39;;
    }
  });

  
  lightbox.onclick = function(e) {
    if (e.target === lightbox) {
      lightbox.style.display = &#39;none&#39;;
    }
  };
})();
&lt;/script&gt;

