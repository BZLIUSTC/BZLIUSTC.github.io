    &lt;/div&gt;
    
    
    
    
    &lt;div class=&#34;picture-item&#34;&gt;
      &lt;div class=&#34;img-container&#34; data-src=&#34;tamako-frontpage.jpg&#34;&gt;
        &lt;div class=&#34;img-inner&#34;&gt;
          &lt;img src=&#34;tamako-frontpage.jpg&#34; alt=&#34;第二张图内容&#34;&gt;
        &lt;/div&gt;
      &lt;/div&gt;
      &lt;div class=&#34;caption-sub&#34;&gt;(b) 第二张图内容&lt;/div&gt;
