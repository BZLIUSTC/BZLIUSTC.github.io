}
.cv-item-head {
  display: flex;
  justify-content: space-between;
  font-weight: 600;
  background: var(--item-box-bg);
  color: var(--item-text-color);
  padding: 8px 14px;
  border-radius: 8px;
  margin-bottom: 8px;
}
.cv-gpa {
